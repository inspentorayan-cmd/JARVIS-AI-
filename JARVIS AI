<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JARVIS — AI Assistant</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;600;700&display=swap');

  :root {
    --bg: #030a0f;
    --bg2: #050f18;
    --panel: #071520;
    --border: #0d3a5c;
    --cyan: #00d4ff;
    --cyan-dim: #00aacc44;
    --cyan-glow: #00d4ff33;
    --green: #00ff9d;
    --orange: #ff6b35;
    --text: #b0d4e8;
    --text-dim: #4a7a99;
    --font-mono: 'Share Tech Mono', monospace;
    --font-ui: 'Rajdhani', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-ui);
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── Header ── */
  header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 24px;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .logo-ring {
    width: 42px; height: 42px;
    border-radius: 50%;
    border: 2px solid var(--cyan);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 16px var(--cyan-glow), inset 0 0 10px var(--cyan-dim);
    animation: pulse 3s ease-in-out infinite;
    flex-shrink: 0;
  }
  .logo-ring svg { width: 22px; height: 22px; fill: var(--cyan); }

  @keyframes pulse {
    0%,100% { box-shadow: 0 0 16px var(--cyan-glow), inset 0 0 10px var(--cyan-dim); }
    50% { box-shadow: 0 0 28px #00d4ff66, inset 0 0 18px #00d4ff55; }
  }

  .header-text h1 {
    font-family: var(--font-ui);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 6px;
    color: var(--cyan);
    text-shadow: 0 0 20px var(--cyan);
  }
  .header-text p {
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }

  .status-bar {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
  }
  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.4} }

  /* ── API Key Banner ── */
  #api-banner {
    background: linear-gradient(90deg, #1a0a00, #0d1a00);
    border-bottom: 1px solid #ff6b3544;
    padding: 10px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  #api-banner span { font-size: 13px; color: #ff9955; font-family: var(--font-mono); }
  #api-key-input {
    flex: 1;
    background: #0a0a0a;
    border: 1px solid #ff6b3566;
    color: #ffcc99;
    font-family: var(--font-mono);
    font-size: 13px;
    padding: 6px 12px;
    border-radius: 4px;
    outline: none;
    max-width: 400px;
  }
  #api-key-input:focus { border-color: var(--orange); }
  #save-key-btn {
    background: var(--orange);
    color: #000;
    border: none;
    padding: 6px 18px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
    border-radius: 4px;
    cursor: pointer;
  }
  #save-key-btn:hover { background: #ff8855; }

  /* ── Main layout ── */
  .main {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  /* ── Sidebar ── */
  .sidebar {
    width: 200px;
    background: var(--bg2);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 16px 0;
    flex-shrink: 0;
  }
  .sidebar-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--text-dim);
    padding: 0 16px 8px;
  }
  .tool-item {
    padding: 8px 16px;
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: all 0.15s;
    border-left: 2px solid transparent;
  }
  .tool-item:hover { color: var(--cyan); border-left-color: var(--cyan); background: var(--cyan-dim); }
  .tool-item.active { color: var(--cyan); border-left-color: var(--cyan); }
  .tool-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--text-dim); flex-shrink: 0; }
  .tool-item:hover .tool-dot, .tool-item.active .tool-dot { background: var(--cyan); box-shadow: 0 0 6px var(--cyan); }

  .sidebar-divider { border: none; border-top: 1px solid var(--border); margin: 12px 0; }

  /* ── Chat area ── */
  .chat-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  #messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  /* Welcome */
  .welcome {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-dim);
  }
  .welcome .big { font-size: 48px; font-weight: 700; color: var(--cyan); letter-spacing: 8px; text-shadow: 0 0 40px var(--cyan); font-family: var(--font-ui); }
  .welcome p { font-family: var(--font-mono); font-size: 13px; margin-top: 8px; }
  .welcome .chips { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 20px; }
  .chip {
    background: var(--panel);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 6px 14px;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .chip:hover { border-color: var(--cyan); color: var(--cyan); background: var(--cyan-dim); }

  /* Messages */
  .msg {
    display: flex;
    gap: 12px;
    max-width: 860px;
    animation: fadein 0.2s ease;
  }
  @keyframes fadein { from { opacity:0; transform: translateY(6px); } to { opacity:1; transform: translateY(0); } }

  .msg.user { align-self: flex-end; flex-direction: row-reverse; }

  .msg-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700;
    flex-shrink: 0;
    font-family: var(--font-mono);
  }
  .msg.jarvis .msg-avatar { background: var(--cyan-dim); border: 1px solid var(--cyan); color: var(--cyan); }
  .msg.user .msg-avatar { background: #1a2a1a; border: 1px solid var(--green); color: var(--green); }

  .msg-bubble {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px 12px 12px 12px;
    padding: 12px 16px;
    font-size: 14px;
    line-height: 1.6;
    max-width: 700px;
  }
  .msg.user .msg-bubble {
    background: #071a0f;
    border-color: #1a4a2a;
    border-radius: 12px 4px 12px 12px;
    color: #ccffdd;
  }
  .msg.jarvis .msg-bubble { color: var(--text); }

  .msg-bubble pre {
    background: #020c14;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 10px 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    overflow-x: auto;
    margin: 8px 0;
    color: var(--cyan);
  }

  .tool-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: #00aacc15;
    border: 1px solid #00aacc33;
    color: #00aacc;
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 3px;
    margin-bottom: 8px;
  }

  /* Typing indicator */
  .typing-indicator {
    display: flex;
    gap: 5px;
    padding: 4px 0;
  }
  .typing-indicator span {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    animation: typing 1.2s ease-in-out infinite;
  }
  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typing { 0%,100%{opacity:0.3;transform:scale(0.8)} 50%{opacity:1;transform:scale(1)} }

  /* ── Input area ── */
  .input-area {
    padding: 16px 24px;
    background: var(--bg2);
    border-top: 1px solid var(--border);
    display: flex;
    gap: 10px;
    align-items: flex-end;
    flex-shrink: 0;
  }

  #user-input {
    flex: 1;
    background: var(--panel);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 14px;
    padding: 12px 16px;
    border-radius: 6px;
    outline: none;
    resize: none;
    min-height: 46px;
    max-height: 120px;
    line-height: 1.5;
    transition: border-color 0.15s;
  }
  #user-input:focus { border-color: var(--cyan); box-shadow: 0 0 0 1px var(--cyan-dim); }
  #user-input::placeholder { color: var(--text-dim); }

  #send-btn {
    background: var(--cyan);
    color: #000;
    border: none;
    width: 46px; height: 46px;
    border-radius: 6px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: all 0.15s;
    font-size: 18px;
  }
  #send-btn:hover { background: #33ddff; box-shadow: 0 0 16px var(--cyan-glow); }
  #send-btn:disabled { background: var(--border); cursor: not-allowed; color: var(--text-dim); }

  /* Scan line effect */
  body::after {
    content: '';
    position: fixed; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,212,255,0.015) 2px, rgba(0,212,255,0.015) 4px);
    pointer-events: none;
    z-index: 9999;
  }
</style>
</head>
<body>

<header>
  <div class="logo-ring">
    <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
  </div>
  <div class="header-text">
    <h1>JARVIS</h1>
    <p>JUST A RATHER VERY INTELLIGENT SYSTEM</p>
  </div>
  <div class="status-bar">
    <div class="status-dot"></div>
    <span id="status-text">SYSTEMS ONLINE</span>
  </div>
</header>

<div id="api-banner">
  <span>⚡ GROQ KEY</span>
  <input type="password" id="api-key-input" placeholder="Paste your Groq API key here (gsk_...)" />
  <button id="save-key-btn" onclick="saveKey()">CONNECT</button>
</div>

<div class="main">
  <div class="sidebar">
    <div class="sidebar-label">TOOLS</div>
    <div class="tool-item active" onclick="sendChip('What time is it?')"><div class="tool-dot"></div>get_time</div>
    <div class="tool-item" onclick="sendChip('Show my system info')"><div class="tool-dot"></div>system_info</div>
    <div class="tool-item" onclick="sendChip('Search the web for latest AI news')"><div class="tool-dot"></div>web_search</div>
    <div class="tool-item" onclick="sendChip('Calculate 2 ** 32')"><div class="tool-dot"></div>calculate</div>
    <div class="tool-item" onclick="sendChip('What can you do?')"><div class="tool-dot"></div>help</div>
    <hr class="sidebar-divider">
    <div class="sidebar-label">MEMORY</div>
    <div class="tool-item" onclick="sendChip('Remember that my name is Tony Stark')"><div class="tool-dot"></div>remember</div>
    <div class="tool-item" onclick="sendChip('What do you remember about me?')"><div class="tool-dot"></div>recall</div>
    <hr class="sidebar-divider">
    <div class="sidebar-label">ACTIONS</div>
    <div class="tool-item" onclick="clearChat()"><div class="tool-dot"></div>clear chat</div>
  </div>

  <div class="chat-area">
    <div id="messages">
      <div class="welcome" id="welcome">
        <div class="big">JARVIS</div>
        <p>Online and ready, sir. How may I assist you today?</p>
        <div class="chips">
          <div class="chip" onclick="sendChip(this.textContent)">What time is it?</div>
          <div class="chip" onclick="sendChip(this.textContent)">Show my system info</div>
          <div class="chip" onclick="sendChip(this.textContent)">Search latest AI news</div>
          <div class="chip" onclick="sendChip(this.textContent)">Calculate (1+5**0.5)/2</div>
          <div class="chip" onclick="sendChip(this.textContent)">What can you do?</div>
          <div class="chip" onclick="sendChip(this.textContent)">Write a Python hello world</div>
        </div>
      </div>
    </div>

    <div class="input-area">
      <textarea id="user-input" placeholder="Ask JARVIS anything..." rows="1"
        onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
      <button id="send-btn" onclick="sendMessage()">➤</button>
    </div>
  </div>
</div>

<script>
let conversationHistory = [];
let groqKey = localStorage.getItem('groq_key') || '';
let isTyping = false;

// Load saved key
if (groqKey) {
  document.getElementById('api-key-input').value = groqKey;
  document.getElementById('api-banner').style.background = 'linear-gradient(90deg, #001a00, #001500)';
  document.getElementById('api-banner').style.borderBottomColor = '#00ff9d44';
  document.getElementById('api-banner').querySelector('span').textContent = '✅ GROQ CONNECTED';
  document.getElementById('api-banner').querySelector('span').style.color = '#00ff9d';
  document.getElementById('save-key-btn').textContent = 'UPDATE';
}

function saveKey() {
  const key = document.getElementById('api-key-input').value.trim();
  if (!key.startsWith('gsk_')) {
    alert('Please enter a valid Groq API key (starts with gsk_)');
    return;
  }
  groqKey = key;
  localStorage.setItem('groq_key', key);
  document.getElementById('api-banner').style.background = 'linear-gradient(90deg, #001a00, #001500)';
  document.getElementById('api-banner').style.borderBottomColor = '#00ff9d44';
  document.getElementById('api-banner').querySelector('span').textContent = '✅ GROQ CONNECTED';
  document.getElementById('api-banner').querySelector('span').style.color = '#00ff9d';
  document.getElementById('save-key-btn').textContent = 'UPDATE';
}

function sendChip(text) {
  document.getElementById('user-input').value = text;
  sendMessage();
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

function clearChat() {
  conversationHistory = [];
  const msgs = document.getElementById('messages');
  msgs.innerHTML = `<div class="welcome" id="welcome">
    <div class="big">JARVIS</div>
    <p>Chat cleared. How may I assist you, sir?</p>
  </div>`;
}

function addMessage(role, content, toolUsed) {
  const welcome = document.getElementById('welcome');
  if (welcome) welcome.remove();

  const msgs = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = `msg ${role}`;

  const avatar = role === 'jarvis' ? 'J' : 'YOU';
  let bubbleContent = '';

  if (toolUsed) {
    bubbleContent += `<div class="tool-badge">⚡ ${toolUsed}</div><br>`;
  }

  // Format code blocks
  const formatted = content
    .replace(/```(\w*)\n?([\s\S]*?)```/g, (_, lang, code) => `<pre>${escapeHtml(code.trim())}</pre>`)
    .replace(/`([^`]+)`/g, '<code style="background:#020c14;padding:1px 5px;border-radius:3px;font-family:var(--font-mono);color:var(--cyan)">$1</code>')
    .replace(/\n/g, '<br>');

  div.innerHTML = `
    <div class="msg-avatar">${avatar}</div>
    <div class="msg-bubble">${bubbleContent}${formatted}</div>
  `;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function escapeHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function showTyping() {
  const msgs = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'msg jarvis';
  div.id = 'typing-msg';
  div.innerHTML = `
    <div class="msg-avatar">J</div>
    <div class="msg-bubble"><div class="typing-indicator"><span></span><span></span><span></span></div></div>
  `;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typing-msg');
  if (t) t.remove();
}

const TOOLS = [
  {type:"function",function:{name:"get_time",description:"Returns current date and time",parameters:{type:"object",properties:{}}}},
  {type:"function",function:{name:"system_info",description:"Returns system and OS info",parameters:{type:"object",properties:{}}}},
  {type:"function",function:{name:"web_search",description:"Search the web for information",parameters:{type:"object",properties:{query:{type:"string",description:"Search query"}},required:["query"]}}},
  {type:"function",function:{name:"calculate",description:"Evaluate a math expression",parameters:{type:"object",properties:{expression:{type:"string"}},required:["expression"]}}},
  {type:"function",function:{name:"remember",description:"Save a fact to memory",parameters:{type:"object",properties:{fact:{type:"string"}}}}},
  {type:"function",function:{name:"recall",description:"Recall everything from memory",parameters:{type:"object",properties:{}}}},
];

// In-memory storage
let memory = JSON.parse(localStorage.getItem('jarvis_memory') || '{"facts":[],"notes":{}}');

function runTool(name, args) {
  switch(name) {
    case 'get_time':
      return `Current date/time: ${new Date().toLocaleString('en-US', {weekday:'long',year:'numeric',month:'long',day:'numeric',hour:'2-digit',minute:'2-digit',second:'2-digit'})}`;
    case 'system_info':
      return JSON.stringify({
        browser: navigator.userAgent.split(' ').slice(-1)[0],
        platform: navigator.platform,
        language: navigator.language,
        online: navigator.onLine,
        screen: `${screen.width}x${screen.height}`,
        cores: navigator.hardwareConcurrency || 'unknown',
        memory_gb: navigator.deviceMemory || 'unknown'
      }, null, 2);
    case 'web_search':
      return `Web search for "${args.query}" — Note: direct search is limited in browser. Here's what I know about this topic based on my training. For live results, use the Python terminal version.`;
    case 'calculate':
      try {
        const safe = args.expression.replace(/[^0-9+\-*/.() **%]/g,'');
        const result = Function('"use strict"; return (' + safe + ')')();
        return `${args.expression} = ${result}`;
      } catch(e) { return `Error: ${e.message}`; }
    case 'remember':
      memory.facts.push({fact: args.fact, at: new Date().toISOString()});
      localStorage.setItem('jarvis_memory', JSON.stringify(memory));
      return `Remembered: ${args.fact}`;
    case 'recall':
      if (!memory.facts.length && !Object.keys(memory.notes).length) return 'Memory is empty.';
      let out = '';
      if (memory.facts.length) out += 'Facts:\n' + memory.facts.slice(-10).map(f=>'• '+f.fact).join('\n');
      return out || 'Memory is empty.';
    default:
      return `Unknown tool: ${name}`;
  }
}

async function callGroq(messages, withTools=true) {
  const body = {
    model: 'llama-3.3-70b-versatile',
    max_tokens: 2048,
    messages: [
      {role:'system', content:`You are JARVIS (Just A Rather Very Intelligent System), a highly capable AI assistant. Be concise, precise, and slightly witty. Occasionally address the user as "sir". Use tools when they help answer the request. Format code in triple backticks.`},
      ...messages
    ]
  };
  if (withTools) body.tools = TOOLS;
  if (withTools) body.tool_choice = 'auto';

  const resp = await fetch('https://api.groq.com/openai/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${groqKey}`
    },
    body: JSON.stringify(body)
  });

  if (!resp.ok) {
    const err = await resp.json();
    throw new Error(err.error?.message || 'API error');
  }
  return await resp.json();
}

async function sendMessage() {
  if (isTyping) return;
  if (!groqKey) { alert('Please enter your Groq API key first!'); return; }

  const input = document.getElementById('user-input');
  const text = input.value.trim();
  if (!text) return;

  input.value = '';
  input.style.height = 'auto';
  document.getElementById('send-btn').disabled = true;
  isTyping = true;

  addMessage('user', text);
  conversationHistory.push({role:'user', content:text});

  showTyping();

  try {
    let messages = [...conversationHistory];
    let toolUsed = null;

    // Agentic loop
    while (true) {
      const data = await callGroq(messages);
      const choice = data.choices[0];
      const msg = choice.message;

      if (msg.tool_calls && msg.tool_calls.length > 0) {
        messages.push({role:'assistant', content: msg.content || '', tool_calls: msg.tool_calls});

        for (const tc of msg.tool_calls) {
          let args = {};
          try { args = JSON.parse(tc.function.arguments || '{}'); } catch(e){}
          toolUsed = tc.function.name;
          const result = runTool(tc.function.name, args);
          messages.push({role:'tool', tool_call_id: tc.id, name: tc.function.name, content: result});
        }
        // continue loop
      } else {
        // Final answer
        conversationHistory.push({role:'assistant', content: msg.content || ''});
        removeTyping();
        addMessage('jarvis', msg.content || '(no response)', toolUsed);
        break;
      }
    }
  } catch(e) {
    removeTyping();
    addMessage('jarvis', `⚠️ Error: ${e.message}. Check your API key and try again.`);
  }

  isTyping = false;
  document.getElementById('send-btn').disabled = false;
  document.getElementById('user-input').focus();
}
</script>
</body>
</html>
